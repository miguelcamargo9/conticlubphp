{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^7.2.5",
        "aws/aws-sdk-php": "^3.276 <3.324",
        "fideloper/proxy": "^4.2",
        "laravel/framework": "^6.0",
        "laravel/passport": "^9.3",
        "laravel/tinker": "^2.0",
        "lcobucci/jwt": "^3.4",
        "league/flysystem-aws-s3-v3": "^1.0",
        "ext-json": "*",
        "ext-pdo": "*"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^2.8 <2.13",
        "fakerphp/faker": "^1.9",
        "filp/whoops": "^2.0",
        "krlove/eloquent-model-generator": "^1.3",
        "mockery/mockery": "^1.3",
        "nunomaduro/collision": "^3.0",
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^8.5",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "audit": {
            "abandoned": "report",
            "ignore": {
                "PKSA-4t1p-xpk2-nsss": "aws/aws-sdk-php — known, pinned on conservative upgrade path",
                "PKSA-dxyf-6n16-t87m": "aws/aws-sdk-php — known, pinned on conservative upgrade path",
                "PKSA-n3s6-289w-qtqb": "aws/aws-sdk-php — known, pinned on conservative upgrade path",
                "PKSA-stsw-jsf7-f6vs": "aws/aws-sdk-php — known, pinned on conservative upgrade path",
                "PKSA-y2cr-5h3j-g3ys": "firebase/php-jwt — transitive via Passport 9, bounded by L6",
                "PKSA-2kqm-ps5x-s4f5": "firebase/php-jwt — transitive via Passport 9, bounded by L6"
            }
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "App\\Models\\": "app/Models/"
        },
        "classmap": [
            "database/seeds",
            "database/factories"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "phpcs": "phpcs --standard=PSR2 app/"
    }
}
